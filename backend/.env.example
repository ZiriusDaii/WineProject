DATABASE_URL=postgresql://<usuario>:<password>@localhost:5432/winespa
# En produccion, si la base no esta en la misma red privada que el backend,
# agregar `?sslmode=require` al final de la URL -- sin eso, la conexion (y los
# datos de clientes que viajan por ella) va sin cifrar.
PORT=3000
# Opcional en dev (sin definir, acepta cualquier origen). OBLIGATORIO si
# NODE_ENV=production -- el server rechaza arrancar sin esto en produccion.
# CORS_ORIGIN=http://localhost:5173,https://tu-dominio.com
# Firma los JWT de sesion (staff y cliente). Sin definir, usa un secreto de dev
# hardcodeado (backend/src/lib/jwt.ts) -- cambiar antes de produccion.
JWT_SECRET=<generar-un-secreto-largo-y-aleatorio>

# Meta WhatsApp Cloud API Credentials
WHATSAPP_TOKEN=<token-de-acceso-de-meta>
WHATSAPP_PHONE_NUMBER_ID=<id-del-numero-de-telefono>
WHATSAPP_WABA_ID=<waba-id>
WHATSAPP_VERIFY_TOKEN=<token-de-verificacion-del-webhook>
# App Secret de la app de Meta (no el token de acceso) -- firma cada webhook
# entrante con HMAC-SHA256 (header X-Hub-Signature-256). Sin esto el servidor
# rechaza todos los webhooks (falla cerrado): sin verificar la firma, cualquiera
# que sepa la URL podria simular un mensaje entrante y hacer que el bot le
# responda de verdad, vía la cuenta real, a cualquier numero.
WHATSAPP_APP_SECRET=<app-secret-de-la-app-de-meta>
WHATSAPP_TEST_NUMBER=<numero-de-prueba-de-whatsapp>
FRONTEND_URL=http://localhost:5173
