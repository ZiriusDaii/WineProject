generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MANICURISTA
  CLIENTE
}

enum AppointmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WhatsAppDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  RECEIVED
  SENT
  DELIVERED
  READ
  FAILED
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  username  String?  @unique
  password  String?
  avatarPath String?  @map("avatar_path")
  name      String
  age       Int?
  gender    String?
  role      Role     @default(CLIENTE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedules              ManicuristSchedule[]
  clientAppointments     Appointment[]        @relation("ClientAppointments")
  manicuristAppointments Appointment[]        @relation("ManicuristAppointments")

  @@map("users")
}

model Service {
  id                  String   @id @default(uuid())
  name                String
  shortDescription    String?  @map("short_description")
  includesDescription String?  @map("includes_description")
  category            String?
  imageUrl            String?  @map("image_url")
  price               Decimal  @db.Decimal(10, 2)
  durationInMinutes   Int      @map("duration_in_minutes")
  trending            Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("services")
}

model ServiceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("service_categories")
}

model ShiftTemplate {
  id        String @id @default(uuid())
  name      String
  startTime String @map("start_time")
  endTime   String @map("end_time")

  schedules ManicuristSchedule[]

  @@map("shift_templates")
}

model ManicuristSchedule {
  id              String        @id @default(uuid())
  manicuristId    String        @map("manicurist_id")
  shiftTemplateId String        @map("shift_template_id")
  weekNumber      Int           @map("week_number")
  year            Int
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  manicurist    User          @relation(fields: [manicuristId], references: [id])
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])

  @@unique([manicuristId, weekNumber, year])
  @@map("manicurist_schedules")
}

model Appointment {
  id            String            @id @default(uuid())
  clientId      String            @map("client_id")
  manicuristId  String            @map("manicurist_id")
  date          DateTime
  totalDuration Int               @map("total_duration")
  totalPrice    Decimal           @db.Decimal(10, 2) @map("total_price")
  status        AppointmentStatus @default(PENDING)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  client     User      @relation("ClientAppointments", fields: [clientId], references: [id])
  manicurist User      @relation("ManicuristAppointments", fields: [manicuristId], references: [id])
  services   Service[]

  @@map("appointments")
}

model SpecialOffer {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  discountPercentage Int       @map("discount_percentage")
  code               String    @unique
  isActive           Boolean   @default(true) @map("is_active")
  validFrom          DateTime? @map("valid_from")
  validUntil         DateTime? @map("valid_until")
  newUsersOnly       Boolean   @default(false) @map("new_users_only")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("special_offers")
}

model LandingContent {
  id          String   @id @default(uuid())
  type        String
  title       String
  description String?
  imageUrl    String   @map("image_url")
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("landing_content")
}

model WhatsAppMessage {
  id             String                @id @default(uuid())
  waMessageId    String?               @unique @map("wa_message_id")
  from           String
  to             String
  body           String
  direction      WhatsAppDirection
  status         WhatsAppMessageStatus @default(RECEIVED)
  conversationId String                @map("conversation_id")
  flagged        Boolean               @default(false)
  createdAt      DateTime              @default(now()) @map("created_at")

  @@index([from])
  @@index([conversationId])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

model WhatsAppTemplate {
  id           String   @id @default(uuid())
  name         String   @unique
  headerText   String   @map("header_text")
  bodyText     String   @map("body_text")
  button1Id    String   @default("agendar_cita") @map("button1_id")
  button1Title String   @default("Agendar Cita") @map("button1_title")
  button2Id    String   @default("modificar_cita") @map("button2_id")
  button2Title String   @default("Modificar Cita") @map("button2_title")
  button3Id    String   @default("solicitar_asesor") @map("button3_id")
  button3Title String   @default("Solicitar Asesor") @map("button3_title")
  isActive     Boolean  @default(true) @map("is_active")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_templates")
}
